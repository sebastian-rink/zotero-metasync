{
  "name": "metasync",
  "type": "module",
  "version": "0.1.0",
  "description": "MetaSync – Anreicherung und Korrektur von Zotero-Metadaten aus Online-Bibliotheksquellen",
  "config": {
    "addonName": "MetaSync",
    "addonID": "metasync@sebastianrink.de",
    "addonRef": "metasync",
    "addonInstance": "MetaSync",
    "prefsPrefix": "extensions.zotero.metasync"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-rink/zotero-metasync.git"
  },
  "author": "Sebastian Rink",
  "bugs": {
    "url": "https://github.com/sebastian-rink/zotero-metasync/issues"
  },
  "homepage": "https://github.com/sebastian-rink/zotero-metasync#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit && cp .scaffold/build/meta-sync.xpi ./MetaSync.xpi",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.4"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.6",
    "prettier": "^3.9.1",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.6",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
